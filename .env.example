# OpenAI (for embeddings, used by both ingestion scripts and search endpoints)
OPENAI_API_KEY=sk-...

# Postgres
DATABASE_URL=postgresql://bhante:bhante@localhost:5433/bhante

# Better Auth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=changeme-min-32-chars-replace-this-value
BETTER_AUTH_URL=http://localhost:5173

# Voyage AI reranker (optional). When RERANK_ENABLED=true and VOYAGE_API_KEY
# is set, search over-fetches RERANK_OVERFETCH × k candidates from pgvector
# and reranks them with Voyage. Falls back to pgvector order on API errors.
# Defaults: disabled, rerank-2.5-lite, 4× over-fetch (k=5 → 20 candidates).
VOYAGE_API_KEY=
RERANK_ENABLED=false
RERANK_MODEL=rerank-2.5-lite
RERANK_OVERFETCH=4

# Admin gate. Comma-separated list of emails to bootstrap as is_admin=true on
# every migrate run. Leave empty in environments without admins.
ADMIN_EMAILS=

# Require admins to enrol TOTP before /admin/* is reachable. Off in dev (admin
# can log in without a phone), on in prod. Users can always enrol TOTP
# voluntarily — this only enforces it for admins.
ADMIN_REQUIRE_TOTP=false

# Feedback widget — Slack notification (optional). When set, every new report
# fires a fire-and-forget POST to this Incoming Webhook. Webhook failures are
# logged but never block submit.
FEEDBACK_SLACK_WEBHOOK_URL=

# Feedback widget — R2 bucket for screenshot uploads. Use a SEPARATE bucket
# from R2_BUCKET (db backups). Leave R2_FEEDBACK_BUCKET empty to disable
# screenshot capture (the form still submits, just without a screenshot).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FEEDBACK_BUCKET=
