# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# Supabase Auth
# Project URL (no trailing slash)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon (public) key — only used by the frontend (VITE_SUPABASE_ANON_KEY below).
# The backend does NOT need the anon key; it validates JWTs via the JWKS endpoint.

# Optional overrides (defaults are usually correct):
# SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

# Frontend env (read by Vite; copy into src/client/.env)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
